+// ─────────────────────────────────────────────
+// CUSTOM KINETIC PROTOCOL ANIMATIONS
+// ─────────────────────────────────────────────
+
+/**
+ * Ink Bleed Reveal Animation
+ * 
+ * Simulates ink bleeding onto parchment by starting with a slight blur,
+ * lower opacity, and reduced scale, then slowly transitioning into full focus.
+ * 
+ * Animation details:
+ * - Uses a custom easing curve [0.25, 0.1, 0.25, 1] which provides a smooth,
+ *   lingering deceleration, similar to fluid movement.
+ * - Duration is set to 1.2 seconds to emphasize the slow, deliberate nature
+ *   of ink soaking into physical paper.
+ */
+function InkBleedReveal({ children, delay = 0, className = "" }: { children: React.ReactNode; delay?: number; className?: string }) {
+  const ref = useRef(null)
+  const isInView = useInView(ref, { once: true, margin: '-10% 0px' })
+  const shouldReduce = useReducedMotion()
+
+  return (
+    <motion.div
+      ref={ref}
+      initial={shouldReduce ? false : { opacity: 0, filter: 'blur(10px)', scale: 0.95 }}
+      animate={isInView ? { opacity: 1, filter: 'blur(0px)', scale: 1 } : {}}
+      transition={{ duration: 1.2, delay, ease: [0.25, 0.1, 0.25, 1] }}
+      className={className}
+    >
+      {children}
+    </motion.div>
+  )
+}
+
+/**
+ * Slow Unfolding Scroll Animation
+ * 
+ * Mimics a piece of heavy parchment or an old manuscript unfurling as the user
+ * scrolls down the page. It rotates along the X-axis while moving upwards.
+ * 
+ * Animation details:
+ * - Uses transformPerspective: 1000 to give depth to the 3D rotation without
+ *   requiring parent container classes.
+ * - Easing curve [0.22, 1, 0.36, 1] (easeOut) provides a natural unfurling motion
+ *   that settles gently at the end.
+ * - The transformOrigin is set to 'top center' so it feels like it's unfolding
+ *   from a pinned top edge.
+ */
+function PaperUnfold({ children, delay = 0, className = "" }: { children: React.ReactNode; delay?: number; className?: string }) {
+  const ref = useRef(null)
+  const isInView = useInView(ref, { once: true, margin: '-10% 0px' })
+  const shouldReduce = useReducedMotion()
+
+  return (
+    <motion.div
+      ref={ref}
+      initial={shouldReduce ? false : { opacity: 0, rotateX: -15, y: 40, transformPerspective: 1000 }}
+      animate={isInView ? { opacity: 1, rotateX: 0, y: 0 } : {}}
+      transition={{ duration: 1, delay, ease: [0.22, 1, 0.36, 1] }}
+      style={{ transformOrigin: 'top center' }}
+      className={`relative ${className}`}
+    >
+      <div
+        className="absolute inset-0 pointer-events-none mix-blend-overlay z-0 rounded"
+        style={{
+          opacity: 0.05,
+          backgroundImage: `url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E")`
+        }}
+      />
+      <div className="relative z-10">{children}</div>
+    </motion.div>
+  )
 }
 
