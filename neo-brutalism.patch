+interface BrutalButtonProps {
+  variant?: 'primary' | 'secondary' | 'outline' | 'white';
+  children: React.ReactNode;
+  className?: string;
+  onClick?: React.MouseEventHandler<HTMLButtonElement>;
+  type?: "button" | "submit" | "reset";
+  disabled?: boolean;
+}
+
+function BrutalButton({ variant = 'primary', children, className = '', onClick, type, disabled }: BrutalButtonProps) {
+  let bg = tokens.accent
+  let text = tokens.foreground
+  
+  if (variant === 'secondary') bg = tokens.secondary
+  if (variant === 'outline') { bg = tokens.background; text = tokens.foreground }
+  if (variant === 'white') { bg = tokens.white; text = tokens.foreground }
+
+  return (
+    <motion.button
+      className={`relative uppercase font-bold tracking-widest text-sm border-4 border-black h-14 px-8 flex items-center justify-center gap-2 ${className}`}
+      style={{ 
+        backgroundColor: bg, 
+        color: text,
+        boxShadow: tokens.shadowSm
+      }}
+      whileHover={{ y: -2, x: -2, boxShadow: tokens.shadowMd }}
+      whileTap={{ y: 4, x: 4, boxShadow: '0px 0px 0px 0px #000' }}
+      transition={{ duration: 0.1 }}
+      onClick={onClick}
+      type={type}
+      disabled={disabled}
+    >
+      {children}
+    </motion.button>
+  )
 }
 
